# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5433/DATABASE?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRY_DAYS=7

# CORS (comma-separated origins, e.g. http://localhost:3000,https://conference.anpmp.org)
CORS_ORIGINS=http://localhost:3000

# Auth cookies: in production, SameSite=None; Secure (cross-origin SPA + API). Override: AUTH_COOKIE_CROSS_SITE=true|false
# AUTH_COOKIE_CROSS_SITE=true

# Admin creation - code exchanged for token
ADMIN_CODE=your-admin-code

# Cloudinary (media uploads - folder: anpmplagos-conference)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_BASE_URL=https://api.paystack.co
# Fallback if a flow-specific URL below is omitted
PAYSTACK_CALLBACK_URL=http://localhost:3000/payment/callback
# Optional: different frontend return URLs per flow (after Paystack checkout)
PAYSTACK_CALLBACK_URL_BOOTH=http://localhost:3000/payment/callback/booth
PAYSTACK_CALLBACK_URL_SESSION=http://localhost:3000/payment/callback/session
PAYSTACK_CALLBACK_URL_HOTEL_ROOM=http://localhost:3000/payment/callback/hotel
PAYSTACK_CALLBACK_URL_SPONSORSHIP_PLAN=http://localhost:3000/payment/callback/sponsorship
PAYSTACK_CALLBACK_URL_ADVERT_SLOT=http://localhost:3000/payment/callback/advert-slot
PAYSTACK_CALLBACK_URL_BRANDING_SLOT=http://localhost:3000/payment/callback/branding-slot
PAYSTACK_WEBHOOK_SECRET_ENABLED=true

# Frontend URL used for hyperlinks in support emails
FRONTEND_URL=http://localhost:3000

# Support tickets (emails)
SUPPORT_EMAILS=support1@example.com,support2@example.com
SUPPORT_EMAIL_FROM="Support Team <support@example.com>"

# SMTP settings for @nestjs-modules/mailer (nodemailer).
# All four must be set for real delivery; otherwise the app still boots but uses a no-op stream transport (dev).
SUPPORT_SMTP_HOST=smtp.example.com
SUPPORT_SMTP_PORT=587
SUPPORT_SMTP_USER=smtp-username
SUPPORT_SMTP_PASS=smtp-password