// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum RegType {
  member
  attendee
  company
  admin
}

enum ConferenceProfileKind {
  speaker
  special_guest
}

enum ConferenceProfileHighlightType {
  keynote
  featured
}

enum AdminType {
  superadmin
  support
  moderator
}

enum RegistrationStatus {
  pending_payment
  registered
  cancelled
}

enum SponsorTier {
  headliner
  platinum
  gold
  silver
}

enum SessionStatus {
  draft
  published
  cancelled
}

enum PaymentKind {
  registration
  booth
  masterclass
  panel
  presentation
  hotel_room
  sponsorship_plan
  advert_slot
  branding_slot
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum EventPassType {
  conference
  hotel
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  password           String
  regType            RegType
  registrationStatus RegistrationStatus @default(pending_payment)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  member             Member?
  attendee           Attendee?
  company            Company?
  admin              Admin?
  refreshTokens      RefreshToken[]
  payments           Payment[]
  hotelRoomsBooked   HotelRoom[]        @relation("HotelRoomBooking")
  supportTickets     SupportTicket[]
  eventPasses        EventPass[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Admin {
  id                     String                  @id @default(cuid())
  userId                 String                  @unique
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  adminType              AdminType
  avatar                 String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  supportTicketResponses SupportTicketResponse[]
}

model Member {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug             String   @unique
  fullName         String
  phone            String
  bio              String?
  anpmpId          String
  hasSpouse        Boolean
  spouseName       String?
  spouseEmail      String?
  spousePhone      String?
  primarySpecialty String
  hospitalOrg      String
  avatar           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Attendee {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug             String   @unique
  fullName         String
  phone            String
  bio              String?
  inMedicalField   Boolean
  primarySpecialty String?
  hospitalOrg      String?
  occupation       String?
  avatar           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Company {
  id                       String                  @id @default(cuid())
  userId                   String                  @unique
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                     String                  @unique
  companyName              String
  tagline                  String?
  description              String                  @default("")
  boothPreference          String?
  website                  String?
  contactEmail             String
  primaryContactName       String
  primaryContactPhone      String
  headerImage              String?
  logo                     String?
  profileViews             Int                     @default(0)
  sponsorshipPaidTotalKobo Int                     @default(0)
  highestSponsorshipTier   SponsorTier?           @default(silver)
  booth                    Booth?
  representatives          CompanyRepresentative[]
  products                 CompanyProduct[]
  leads                    CompanyLead[]
  payments                 Payment[]
  masterclasses            Masterclass[]           @relation("MasterclassTakenBy")
  panels                   PanelSession[]          @relation("PanelSessionTakenBy")
  presentations            Presentation[]          @relation("PresentationTakenBy")
  advertSlots              AdvertSlot[]            @relation("CompanyAdvertSlots")
  brandingSlots            BrandingSlot[]          @relation("CompanyBrandingSlots")
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
}

model CompanyProduct {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  description        String   @default("")
  imageUrl           String?
  linkUrl            String?
  sortOrder          Int      @default(0)
  whatsappClickCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
}

model CompanyLead {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String?
  email     String?
  phone     String?
  message   String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model CompanyRepresentative {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  title     String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model HotelRoom {
  id          String    @id @default(cuid())
  hotelName   String
  roomType    String
  description String?
  price       Int
  isBooked    Boolean   @default(false)
  isReserved  Boolean   @default(false)
  bookedById  String?
  bookedBy    User?     @relation("HotelRoomBooking", fields: [bookedById], references: [id], onDelete: SetNull)
  payments    Payment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([hotelName])
  @@index([isBooked, isReserved])
  @@index([bookedById])
}

model Booth {
  id          String       @id @default(cuid())
  name        String
  size        String
  price       Int // kobo (1 NGN = 100 kobo)
  boothImage  String?
  description String?
  tier        SponsorTier?
  isTaken     Boolean      @default(false)
  isReserved  Boolean      @default(false)
  takenById   String?      @unique
  takenBy     Company?     @relation(fields: [takenById], references: [id], onDelete: SetNull)
  payments    Payment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tier])
}

model AdvertSlot {
  id          String    @id @default(cuid())
  title       String
  image       String
  price       Int // kobo
  description String?
  isTaken     Boolean   @default(false)
  isReserved  Boolean   @default(false)
  takenById   String?
  takenBy     Company?  @relation("CompanyAdvertSlots", fields: [takenById], references: [id], onDelete: SetNull)
  payments    Payment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
}

model BrandingSlot {
  id          String    @id @default(cuid())
  title       String
  image       String
  price       Int // kobo
  description String?
  isTaken     Boolean   @default(false)
  isReserved  Boolean   @default(false)
  takenById   String?
  takenBy     Company?  @relation("CompanyBrandingSlots", fields: [takenById], references: [id], onDelete: SetNull)
  payments    Payment[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
}

model RegistrationPlan {
  id        String   @id @default(cuid())
  name      String
  price     Int // kobo (1 NGN = 100 kobo)
  perks     String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SponsorshipPlan {
  id          String      @id @default(cuid())
  name        String
  priceInKobo Int
  tier        SponsorTier
  perks       String[]
  isActive    Boolean     @default(true)
  payments    Payment[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Masterclass {
  id          String        @id @default(cuid())
  title       String
  description String
  priceInKobo Int
  isTaken     Boolean       @default(false)
  isReserved  Boolean       @default(false)
  takenById   String?
  takenBy     Company?      @relation("MasterclassTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status      SessionStatus @default(draft)
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
}

model PanelSession {
  id          String        @id @default(cuid())
  title       String
  description String
  priceInKobo Int
  isTaken     Boolean       @default(false)
  isReserved  Boolean       @default(false)
  takenById   String?
  takenBy     Company?      @relation("PanelSessionTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status      SessionStatus @default(draft)
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
}

model Presentation {
  id          String        @id @default(cuid())
  title       String
  description String
  priceInKobo Int
  isTaken     Boolean       @default(false)
  isReserved  Boolean       @default(false)
  takenById   String?
  takenBy     Company?      @relation("PresentationTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status      SessionStatus @default(draft)
  payments    Payment[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
}

model Payment {
  id                String           @id @default(cuid())
  reference         String           @unique
  kind              PaymentKind
  baseAmount        Int
  amount            Int
  status            PaymentStatus    @default(pending)
  provider          String
  providerResponse  Json?
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sponsorshipPlanId String?
  sponsorshipPlan   SponsorshipPlan? @relation(fields: [sponsorshipPlanId], references: [id], onDelete: SetNull)
  boothId           String?
  booth             Booth?           @relation(fields: [boothId], references: [id], onDelete: SetNull)
  masterclassId     String?
  masterclass       Masterclass?     @relation(fields: [masterclassId], references: [id], onDelete: SetNull)
  panelSessionId    String?
  panelSession      PanelSession?    @relation(fields: [panelSessionId], references: [id], onDelete: SetNull)
  presentationId    String?
  presentation      Presentation?    @relation(fields: [presentationId], references: [id], onDelete: SetNull)
  hotelRoomId       String?
  hotelRoom         HotelRoom?       @relation(fields: [hotelRoomId], references: [id], onDelete: SetNull)
  advertSlotId      String?
  advertSlot        AdvertSlot?      @relation(fields: [advertSlotId], references: [id], onDelete: SetNull)
  brandingSlotId    String?
  brandingSlot      BrandingSlot?    @relation(fields: [brandingSlotId], references: [id], onDelete: SetNull)
  paidAt            DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([kind, boothId])
  @@index([kind, masterclassId])
  @@index([kind, panelSessionId])
  @@index([kind, presentationId])
  @@index([kind, hotelRoomId])
  @@index([kind, advertSlotId])
  @@index([kind, brandingSlotId])
  @@index([userId])
  @@index([companyId])
}

model GalleryItem {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
}

model ConferenceProfile {
  id             String                       @id @default(cuid())
  kind           ConferenceProfileKind
  slug           String
  name           String
  profilePicture String
  role           String
  qualifications String
  byline         String
  highlightType  ConferenceProfileHighlightType
  description    String
  websiteLink    String?
  facebookLink   String?
  xLink          String?
  instagramLink  String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@unique([kind, slug])
  @@index([kind, highlightType])
  @@index([kind, name])
}

enum SupportTicketCategory {
  booth
  masterclass
  panel
  presentation
  hotel_room
  directory
  registrations
  sponsorship
  marketing_slots
  company_profile
  payments
  other
}

enum SupportTicketStatus {
  open
  answered
  closed
}

model SupportTicket {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  category    SupportTicketCategory
  description String

  /**
   * Screenshot URLs uploaded to Cloudinary.
   * Kept as a scalar list for simpler storage/queries.
   */
  screenshotUrls String[]

  status SupportTicketStatus @default(open)

  responses SupportTicketResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportTicketResponse {
  id String @id @default(cuid())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  responderAdminId String?
  responderAdmin   Admin?  @relation(fields: [responderAdminId], references: [id], onDelete: SetNull)

  responseText String

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model EventPass {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EventPassType
  qrCodeUrl String
  viewCount Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, type])
  @@index([userId])
}
