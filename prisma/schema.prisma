// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegType {
  member
  attendee
  company
  admin
}

enum ConferenceProfileKind {
  speaker
  special_guest
}

enum ConferenceProfileHighlightType {
  keynote
  featured
}

enum AdminType {
  superadmin
  support
  moderator
}

enum RegistrationStatus {
  pending_payment
  registered
  cancelled
}

/// Company baseline is `default` until a booth or sponsorship plan raises tier. Catalog sponsorship **plans** use bronze–headliner only (validated in app).
enum SponsorTier {
  default
  bronze
  silver
  gold
  platinum
  headliner
}

enum SessionSlotDuration {
  m10
  m15
  m20
  m30
  m45
  h1
  h2
}

enum ConferenceDay {
  day_1
  day_2
}

enum SessionStatus {
  draft
  published
  cancelled
}

enum PaymentKind {
  registration
  order
  booth
  masterclass
  panel
  presentation
  hotel_room
  sponsorship_plan
  advert_slot
  branding_slot
}

enum CartKind {
  conference
  hotel
}

enum CartItemType {
  booth
  masterclass
  panel
  presentation
  sponsorship_plan
  advert_slot
  branding_slot
  hotel_room
}

enum OrderStatus {
  pending_payment
  paid
  cancelled
  failed
}

enum PaymentStatus {
  pending
  success
  failed
  refunded
}

enum EventPassType {
  conference
  hotel
}

model User {
  id                   String             @id @default(cuid())
  email                String             @unique
  password             String
  regType              RegType
  registrationStatus   RegistrationStatus @default(pending_payment)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  member               Member?
  attendee             Attendee?
  company              Company?
  admin                Admin?
  refreshTokens        RefreshToken[]
  payments             Payment[]
  carts                Cart[]
  orders               Order[]
  hotelRoomsBooked     HotelRoom[]        @relation("HotelRoomBooking")
  supportTickets       SupportTicket[]
  eventPasses          EventPass[]
  attendanceAsDelegate AttendanceRecord[]    @relation("DelegateAttendance")
  attendanceMarked     AttendanceRecord[]    @relation("ModeratorMarked")
  passwordResetTokens  PasswordResetToken[]
  votes                Vote[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([tokenHash])
}

model Admin {
  id                     String                  @id @default(cuid())
  userId                 String                  @unique
  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                   String
  adminType              AdminType
  avatar                 String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  supportTicketResponses SupportTicketResponse[]
  votingSettingsUpdates  VotingSettings[]
}

model Member {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                  String   @unique
  title                 String?
  fullName              String
  phone                 String
  bio                   String?
  anpmpId               String?
  hasSpouse             Boolean
  spouseName            String?
  spouseEmail           String?
  spousePhone           String?
  primarySpecialty      String
  hospitalOrg           String
  organizationAddress   String   @default("")
  zone                  String   @default("")
  avatar                String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Attendee {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug             String   @unique
  fullName         String
  phone            String
  bio              String?
  inMedicalField   Boolean
  primarySpecialty String?
  hospitalOrg      String?
  occupation       String?
  avatar           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Company {
  id                       String                  @id @default(cuid())
  userId                   String                  @unique
  user                     User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                     String                  @unique
  companyName              String
  tagline                  String?
  description              String                  @default("")
  boothPreference          String?
  website                  String?
  contactEmail             String
  primaryContactName       String
  primaryContactPhone      String
  headerImage              String?
  logo                     String?
  profileViews             Int                     @default(0)
  sponsorshipPaidTotalKobo BigInt                  @default(0)
  highestSponsorshipTier   SponsorTier?           @default(default)
  booth                    Booth?
  representatives          CompanyRepresentative[]
  products                 CompanyProduct[]
  leads                    CompanyLead[]
  payments                 Payment[]
  masterclasses            Masterclass[]           @relation("MasterclassTakenBy")
  panels                   PanelSession[]          @relation("PanelSessionTakenBy")
  presentations            Presentation[]          @relation("PresentationTakenBy")
  orders                   Order[]
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
}

model CompanyProduct {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  description        String   @default("")
  imageUrl           String?
  linkUrl            String?
  sortOrder          Int      @default(0)
  whatsappClickCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
}

model CompanyLead {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String?
  email     String?
  phone     String?
  message   String?
  createdAt DateTime @default(now())

  @@index([companyId])
}

model CompanyRepresentative {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  title     String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model HotelRoom {
  id                    String    @id @default(cuid())
  hotelName             String
  roomType              String
  description           String?
  price                 Int
  isBooked              Boolean   @default(false)
  isReserved            Boolean   @default(false)
  checkoutHoldExpiresAt DateTime?
  checkoutHoldOrderId   String?
  checkoutHoldPaymentId String?
  bookedById            String?
  bookedBy              User?     @relation("HotelRoomBooking", fields: [bookedById], references: [id], onDelete: SetNull)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([hotelName])
  @@index([isBooked, isReserved])
  @@index([bookedById])
  @@index([checkoutHoldExpiresAt])
}

model Booth {
  id                    String       @id @default(cuid())
  name                  String
  size                  String
  price                 Int // kobo (1 NGN = 100 kobo)
  boothImage            String?
  description           String?
  tier                  SponsorTier?
  isTaken               Boolean      @default(false)
  isReserved            Boolean      @default(false)
  checkoutHoldExpiresAt DateTime?
  checkoutHoldOrderId   String?
  checkoutHoldPaymentId String?
  takenById             String?      @unique
  takenBy               Company?     @relation(fields: [takenById], references: [id], onDelete: SetNull)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([tier])
  @@index([checkoutHoldExpiresAt])
}

model AdvertSlot {
  id                    String    @id @default(cuid())
  title                 String
  image                 String
  price                 Int // kobo
  description           String?
  totalSlots            Int       @default(1)
  availableSlots        Int       @default(1)
  isReserved            Boolean   @default(false)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  sponsorshipPlanLinks  SponsorshipPlanAdvertSlot[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([availableSlots])
  @@index([isReserved])
}

model BrandingSlot {
  id                    String    @id @default(cuid())
  title                 String
  image                 String
  price                 Int // kobo
  description           String?
  totalSlots            Int       @default(1)
  availableSlots        Int       @default(1)
  isReserved            Boolean   @default(false)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  sponsorshipPlanLinks  SponsorshipPlanBrandingSlot[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([availableSlots])
  @@index([isReserved])
}

model RegistrationPlan {
  id        String   @id @default(cuid())
  name      String
  price     Int // kobo (1 NGN = 100 kobo)
  perks     String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SponsorshipPlan {
  id          String      @id @default(cuid())
  name        String
  priceInKobo BigInt
  tier        SponsorTier
  perks       String[]
  isActive    Boolean     @default(true)
  ticketAdmits              Int                  @default(1)
  bundleBoothTier           SponsorTier?
  bundleMasterclassDuration SessionSlotDuration?
  bundleMasterclassDay      ConferenceDay?
  bundlePresentationDuration SessionSlotDuration?
  bundlePresentationDay     ConferenceDay?
  advertSlots               SponsorshipPlanAdvertSlot[]
  brandingSlots             SponsorshipPlanBrandingSlot[]
  payments    Payment[]
  cartItems   CartItem[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model SponsorshipPlanAdvertSlot {
  id                String          @id @default(cuid())
  sponsorshipPlanId String
  sponsorshipPlan   SponsorshipPlan @relation(fields: [sponsorshipPlanId], references: [id], onDelete: Cascade)
  advertSlotId      String
  advertSlot        AdvertSlot      @relation(fields: [advertSlotId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([sponsorshipPlanId, advertSlotId])
  @@index([advertSlotId])
}

model SponsorshipPlanBrandingSlot {
  id                String          @id @default(cuid())
  sponsorshipPlanId String
  sponsorshipPlan   SponsorshipPlan @relation(fields: [sponsorshipPlanId], references: [id], onDelete: Cascade)
  brandingSlotId    String
  brandingSlot      BrandingSlot    @relation(fields: [brandingSlotId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([sponsorshipPlanId, brandingSlotId])
  @@index([brandingSlotId])
}

model Masterclass {
  id                    String        @id @default(cuid())
  title                 String
  description           String
  priceInKobo           Int
  slotDuration          SessionSlotDuration @default(m30)
  conferenceDay         ConferenceDay     @default(day_1)
  isTaken               Boolean       @default(false)
  isReserved            Boolean       @default(false)
  checkoutHoldExpiresAt DateTime?
  checkoutHoldOrderId   String?
  checkoutHoldPaymentId String?
  takenById             String?
  takenBy               Company?      @relation("MasterclassTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status                SessionStatus @default(draft)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
  @@index([checkoutHoldExpiresAt])
}

model PanelSession {
  id                    String        @id @default(cuid())
  title                 String
  description           String
  priceInKobo           Int
  isTaken               Boolean       @default(false)
  isReserved            Boolean       @default(false)
  checkoutHoldExpiresAt DateTime?
  checkoutHoldOrderId   String?
  checkoutHoldPaymentId String?
  takenById             String?
  takenBy               Company?      @relation("PanelSessionTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status                SessionStatus @default(draft)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
  @@index([checkoutHoldExpiresAt])
}

model Presentation {
  id                    String        @id @default(cuid())
  title                 String
  description           String
  priceInKobo           Int
  slotDuration          SessionSlotDuration @default(m30)
  conferenceDay         ConferenceDay     @default(day_1)
  isTaken               Boolean       @default(false)
  isReserved            Boolean       @default(false)
  checkoutHoldExpiresAt DateTime?
  checkoutHoldOrderId   String?
  checkoutHoldPaymentId String?
  takenById             String?
  takenBy               Company?      @relation("PresentationTakenBy", fields: [takenById], references: [id], onDelete: SetNull)
  status                SessionStatus @default(draft)
  payments              Payment[]
  cartItems             CartItem[]
  orderItems            OrderItem[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([takenById])
  @@index([isTaken, isReserved])
  @@index([checkoutHoldExpiresAt])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      CartKind
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, kind])
  @@index([userId])
}

model CartItem {
  id                String       @id @default(cuid())
  cartId            String
  cart              Cart         @relation(fields: [cartId], references: [id], onDelete: Cascade)
  type              CartItemType
  quantity          Int          @default(1)
  boothId           String?
  booth             Booth?       @relation(fields: [boothId], references: [id], onDelete: SetNull)
  masterclassId     String?
  masterclass       Masterclass? @relation(fields: [masterclassId], references: [id], onDelete: SetNull)
  panelSessionId    String?
  panelSession      PanelSession? @relation(fields: [panelSessionId], references: [id], onDelete: SetNull)
  presentationId    String?
  presentation      Presentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)
  sponsorshipPlanId String?
  sponsorshipPlan   SponsorshipPlan? @relation(fields: [sponsorshipPlanId], references: [id], onDelete: SetNull)
  hotelRoomId       String?
  hotelRoom         HotelRoom?   @relation(fields: [hotelRoomId], references: [id], onDelete: SetNull)
  advertSlotId      String?
  advertSlot        AdvertSlot?  @relation(fields: [advertSlotId], references: [id], onDelete: SetNull)
  brandingSlotId    String?
  brandingSlot      BrandingSlot? @relation(fields: [brandingSlotId], references: [id], onDelete: SetNull)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([cartId])
}

model Order {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company?    @relation(fields: [companyId], references: [id], onDelete: SetNull)
  cartKind  CartKind
  status    OrderStatus @default(pending_payment)
  items     OrderItem[]
  payments  Payment[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
}

model OrderItem {
  id                 String       @id @default(cuid())
  orderId            String
  order              Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type               CartItemType
  quantity           Int
  unitBaseAmountKobo BigInt
  titleSnapshot      String?
  boothId            String?
  booth              Booth?       @relation(fields: [boothId], references: [id], onDelete: SetNull)
  masterclassId      String?
  masterclass        Masterclass? @relation(fields: [masterclassId], references: [id], onDelete: SetNull)
  panelSessionId     String?
  panelSession       PanelSession? @relation(fields: [panelSessionId], references: [id], onDelete: SetNull)
  presentationId     String?
  presentation       Presentation? @relation(fields: [presentationId], references: [id], onDelete: SetNull)
  sponsorshipPlanId  String?
  sponsorshipPlan    SponsorshipPlan? @relation(fields: [sponsorshipPlanId], references: [id], onDelete: SetNull)
  hotelRoomId        String?
  hotelRoom          HotelRoom?   @relation(fields: [hotelRoomId], references: [id], onDelete: SetNull)
  advertSlotId       String?
  advertSlot         AdvertSlot?  @relation(fields: [advertSlotId], references: [id], onDelete: SetNull)
  brandingSlotId     String?
  brandingSlot       BrandingSlot? @relation(fields: [brandingSlotId], references: [id], onDelete: SetNull)
  createdAt          DateTime     @default(now())

  @@index([orderId])
}

model Payment {
  id                String           @id @default(cuid())
  reference         String           @unique
  kind              PaymentKind
  baseAmount        BigInt
  amount            BigInt
  status            PaymentStatus    @default(pending)
  provider          String
  providerResponse  Json?
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId         String?
  company           Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  sponsorshipPlanId String?
  sponsorshipPlan   SponsorshipPlan? @relation(fields: [sponsorshipPlanId], references: [id], onDelete: SetNull)
  boothId           String?
  booth             Booth?           @relation(fields: [boothId], references: [id], onDelete: SetNull)
  masterclassId     String?
  masterclass       Masterclass?     @relation(fields: [masterclassId], references: [id], onDelete: SetNull)
  panelSessionId    String?
  panelSession      PanelSession?    @relation(fields: [panelSessionId], references: [id], onDelete: SetNull)
  presentationId    String?
  presentation      Presentation?    @relation(fields: [presentationId], references: [id], onDelete: SetNull)
  hotelRoomId       String?
  hotelRoom         HotelRoom?       @relation(fields: [hotelRoomId], references: [id], onDelete: SetNull)
  advertSlotId      String?
  advertSlot        AdvertSlot?      @relation(fields: [advertSlotId], references: [id], onDelete: SetNull)
  brandingSlotId    String?
  brandingSlot      BrandingSlot?    @relation(fields: [brandingSlotId], references: [id], onDelete: SetNull)
  orderId           String?
  order             Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  sponsorshipResolution Json?
  paidAt            DateTime?
  claimedPaidAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([kind, boothId])
  @@index([kind, masterclassId])
  @@index([kind, panelSessionId])
  @@index([kind, presentationId])
  @@index([kind, hotelRoomId])
  @@index([kind, advertSlotId])
  @@index([kind, brandingSlotId])
  @@index([orderId])
  @@index([userId])
  @@index([companyId])
}

model GalleryItem {
  id        String   @id @default(cuid())
  imageUrl  String
  caption   String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt(sort: Desc)])
}

model ConferenceProfile {
  id             String                       @id @default(cuid())
  kind           ConferenceProfileKind
  slug           String
  name           String
  profilePicture String
  role           String
  qualifications String
  byline         String
  highlightType  ConferenceProfileHighlightType
  description    String
  websiteLink    String?
  facebookLink   String?
  xLink          String?
  instagramLink  String?
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@unique([kind, slug])
  @@index([kind, highlightType])
  @@index([kind, name])
}

enum SupportTicketCategory {
  booth
  masterclass
  panel
  presentation
  hotel_room
  directory
  registrations
  sponsorship
  marketing_slots
  company_profile
  payments
  other
}

enum SupportTicketStatus {
  open
  answered
  closed
}

model SupportTicket {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  category    SupportTicketCategory
  description String

  /**
   * Screenshot URLs uploaded to Cloudinary.
   * Kept as a scalar list for simpler storage/queries.
   */
  screenshotUrls String[]

  status SupportTicketStatus @default(open)

  responses SupportTicketResponse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model SupportTicketResponse {
  id String @id @default(cuid())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  responderAdminId String?
  responderAdmin   Admin?  @relation(fields: [responderAdminId], references: [id], onDelete: SetNull)

  responseText String

  createdAt DateTime @default(now())

  @@index([ticketId, createdAt])
}

model EventPass {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      EventPassType
  qrCodeUrl String
  viewCount Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([userId, type])
  @@index([userId])
}

/// Pending invite for a new attendance moderator account.
model ModeratorInvite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

/// Short-lived token used to reset a user's password (expires in 1 hour).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

/// A single calendar day of the conference during which attendance can be marked.
model EventDay {
  id          String             @id @default(cuid())
  label       String
  date        DateTime
  isActive    Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  attendances AttendanceRecord[]

  @@index([date])
  @@index([isActive])
}

/// One entry slot used by a delegate on a conference day.
model AttendanceRecord {
  id           String    @id @default(cuid())
  userId       String
  eventDayId   String
  markedById   String
  entryIndex   Int
  markedAt     DateTime  @default(now())

  user         User      @relation("DelegateAttendance", fields: [userId], references: [id], onDelete: Cascade)
  eventDay     EventDay  @relation(fields: [eventDayId], references: [id], onDelete: Cascade)
  markedBy     User      @relation("ModeratorMarked", fields: [markedById], references: [id], onDelete: Cascade)

  @@unique([userId, eventDayId, entryIndex])
  @@index([userId, eventDayId])
  @@index([eventDayId])
  @@index([markedById])
}

// ─── Elections ───────────────────────────────────────────────────────────────

model VotingSettings {
  id            String    @id @default(cuid())
  isActive      Boolean   @default(false)
  activatedAt   DateTime?
  deactivatedAt DateTime?
  updatedAt     DateTime  @updatedAt
  updatedById   String?
  updatedBy     Admin?    @relation(fields: [updatedById], references: [id])
}

model ElectionPosition {
  id          String      @id @default(cuid())
  title       String
  description String?
  order       Int         @default(0)
  isActive    Boolean     @default(true)
  candidates  Candidate[]
  votes       Vote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Candidate {
  id         String           @id @default(cuid())
  name       String
  bio        String?
  avatar     String?
  positionId String
  position   ElectionPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  votes      Vote[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([positionId])
}

model Vote {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId  String
  position    ElectionPosition @relation(fields: [positionId], references: [id], onDelete: Restrict)
  candidateId String
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Restrict)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime         @default(now())

  @@unique([userId, positionId])
  @@index([positionId])
  @@index([userId])
}
